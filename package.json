{
  "name": "simple-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "cf:pages:build": "pnpm build",
    "cf:pages:dev": "pnpm cf:pages:build && wrangler pages dev out",
    "cf:pages:deploy": "wrangler pages deploy out --project-name augustus-barbearia-site",
    "build:export": "pnpm build",
    "start:out": "npx serve out",
    "start": "next start",
    "lint": "next lint",
    "sync:data": "pwsh ./scripts/sync-reference-data.ps1",
    "hero:variants": "pwsh ./scripts/generate-hero-variants.ps1",
    "create:client": "node ./scripts/create-client-profile.mjs",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:navigation": "playwright test tests/e2e/navigation.spec.ts",
    "test": "pnpm test:unit && pnpm build && pnpm test:e2e",
    "test:cloudflare": "pnpm cf:pages:build && node ./scripts/verify-cloudflare-output.mjs"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "aos": "3.0.0-beta.6",
    "next": "^15.1.11",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.0.3",
    "@playwright/test": "^1.54.2",
    "@types/aos": "^3.0.7",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.0.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9",
    "wrangler": "^4.20.5"
  },
  "overrides": {
    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3"
  },
  "engines": {
    "node": ">=18.18 <23",
    "npm": ">=8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "packageManager": "pnpm@10.15.1+sha512.34e538c329b5553014ca8e8f4535997f96180a1d0f614339357449935350d924e22f8614682191264ec33d1462ac21561aff97f6bb18065351c162c7e8f6de67"
