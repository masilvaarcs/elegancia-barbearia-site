# Active client profile (must exist in app/lib/clients/index.ts)
NEXT_PUBLIC_CLIENT_ID=elegancia

# Canonical public URL used in metadata/open graph
NEXT_PUBLIC_SITE_URL=https://elegancia-barbearia-site.vercel.app

# WhatsApp routing configuration by environment
# Development (pnpm dev): uses NEXT_PUBLIC_WHATSAPP_DEV_PHONE when provided.
NEXT_PUBLIC_WHATSAPP_DEV_PHONE=

# Production build/deploy: uses NEXT_PUBLIC_WHATSAPP_PROD_PHONE.
# If empty, fallback is the default phone from the active client profile in app/lib/clients/*.ts.
NEXT_PUBLIC_WHATSAPP_PROD_PHONE=5551984228067

# DEV-only commercial/theme overrides (ignored in production)
# Use only in .env.development.local when testing paid feature releases.
# NEXT_PUBLIC_DEV_PLAN_TIER=basic|normal|premium|superPremium
NEXT_PUBLIC_DEV_PLAN_TIER=premium

# NEXT_PUBLIC_DEV_THEME_MODE=randomOnLoad|fixed
NEXT_PUBLIC_DEV_THEME_MODE=
# Optional when NEXT_PUBLIC_DEV_THEME_MODE=fixed
NEXT_PUBLIC_DEV_THEME_FIXED_VARIANT_ID=
NEXT_PUBLIC_DEV_THEME_FIXED_VARIANT_INDEX=

