# WhatsApp routing configuration by environment
# Development (pnpm dev): uses NEXT_PUBLIC_WHATSAPP_DEV_PHONE when provided.
NEXT_PUBLIC_WHATSAPP_DEV_PHONE=

# Production build/deploy: uses NEXT_PUBLIC_WHATSAPP_PROD_PHONE.
# If empty, fallback is the default phone hardcoded in app/lib/augustus-data.ts.
NEXT_PUBLIC_WHATSAPP_PROD_PHONE=5551981311911
